<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/RelativeLayout01"
    android:background="@drawable/pop_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/relativeLayout1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true">
        <TextView
            android:id="@+id/textView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="To learn how to connect to Ableton visit  "/>
        <Button
            android:textColor="#ffffff"
            android:id="@+id/textView2"
            android:paddingLeft="0dp"
            android:paddingTop="0dp"
            android:paddingRight="0dp"
            android:paddingBottom="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="http://bassapps.de"
            android:layout_toRightOf="@+id/textView1"
            android:layout_alignBaseline="@+id/textView1"
            android:layout_alignParentTop="true"
            style="@android:style/Widget.TextView"/>
        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2017    -    Alexander Nowak    -"
            android:layout_below="@+id/textView1"
            android:layout_alignParentLeft="true"/>
        <TextView
            android:id="@+id/textView3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="      mss.geoteach@gmail.com"
            android:layout_alignBaseline="@+id/textView4"
            android:layout_alignRight="@+id/textView2"
            android:layout_alignBottom="@+id/textView4"/>
        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" "
            android:layout_below="@+id/textView4"
            android:layout_alignParentLeft="true"/>
        <Button
            android:textColor="#ffffff"
            android:id="@+id/textFacebook"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Facebook"
            android:layout_below="@+id/textView5"
            android:layout_alignParentLeft="true"
            style="@android:style/Widget.TextView"/>
        <Button
            android:textColor="#ffffff"
            android:id="@+id/textClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            android:layout_alignBaseline="@+id/textFacebook"
            android:layout_alignRight="@+id/textView3"
            android:layout_alignBottom="@+id/textFacebook"
            style="@android:style/Widget.TextView"/>
        <Button
            android:textColor="#ffffff"
            android:id="@+id/textYoutube"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="16dp"
            android:text="YouTube"
            android:layout_alignBaseline="@+id/textClose"
            android:layout_alignBottom="@+id/textClose"
            android:layout_centerHorizontal="true"
            style="@android:style/Widget.TextView"/>
    </RelativeLayout>
    <Button
        android:textColor="#ffffff"
        android:id="@+id/usb"
        android:background="@drawable/but_bg"
        android:paddingLeft="8dp"
        android:paddingTop="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="USB"
        android:layout_below="@+id/relativeLayout1"
        android:layout_centerHorizontal="true"
        style="@android:style/Widget.TextView"/>
    <Button
        android:textColor="#ffffff"
        android:id="@+id/quit"
        android:background="@drawable/but_bg"
        android:paddingLeft="8dp"
        android:paddingTop="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="Quit Launch Buttons"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        style="@android:style/Widget.TextView"/>
</RelativeLayout>
