<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#d74100"
                android:endColor="#772200"
                android:angle="270"
                android:type="radial"
                android:gradientRadius="120"
                android:centerColor="#942f00"/>
            <stroke
                android:width="1dp"
                android:color="#000000"/>
            <corners android:radius="9dp"/>
            <padding
                android:left="10dp"
                android:top="10dp"
                android:right="10dp"
                android:bottom="10dp"/>
        </shape>
    </item>
</selector>
