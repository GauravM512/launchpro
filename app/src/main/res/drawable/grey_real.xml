<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#ffffff"
                android:endColor="#efefef"
                android:angle="270"
                android:type="radial"
                android:gradientRadius="40"
                android:centerColor="#f9f9f9"/>
            <stroke
                android:width="1dp"
                android:color="#333333"/>
            <corners android:radius="9dp"/>
            <padding
                android:left="10dp"
                android:top="10dp"
                android:right="10dp"
                android:bottom="10dp"/>
        </shape>
    </item>
</selector>
